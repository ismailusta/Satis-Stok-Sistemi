DATABASE_URL=mongodb://127.0.0.1/your-database-name
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Mağaza URL (İyzico callback: /api/payment/iyzico/callback/[siparişId] — sonda / olmadan)
# Yerelde tünel (ngrok vb.) veya LAN: http://192.168.1.24:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# İyzico — sandbox: https://sandbox-api.iyzipay.com | canlı: https://api.iyzipay.com
IYZIPAY_URI=https://sandbox-api.iyzipay.com
IYZIPAY_API_KEY=sandbox-xxxx
IYZIPAY_SECRET_KEY=sandbox-xxxx
# Sandbox test TC (11 hane); canlıda gerçek bilgi kullanın
# IYZIPAY_BUYER_IDENTITY_NUMBER=11111111111
# İsteğe bağlı: alıcı e-postası sabitlensin (geçerli alan adı; .local kullanmayın)
# IYZIPAY_BUYER_EMAIL=noreply@sirketiniz.com

# Telefon / tablet ile aynı ağdan geliştirme (npm run dev:lan)
# Windows: ipconfig → IPv4 Adresi (örn. 192.168.1.24)
# LAN_DEV_ORIGIN=http://192.168.1.24:3000
